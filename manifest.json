{
  "manifest_version": 3,
  "name": "Tokenly",
  "version": "0.1.1",
  "description": "See your Claude.ai usage limits at a glance.",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Tokenly",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
