{
  "manifest_version": 3,
  "name": "Tokenly",
  "version": "0.0.3",
  "description": "See your Claude.ai usage at a glance. More AI tools coming.",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Tokenly"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
